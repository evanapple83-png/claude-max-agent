# ─────────────────────────────────────────────────────────────────────────────
#  claude-max-agent — configuration
#  Copy this file to `.env` and fill in what you need. Everything is optional
#  except a Telegram bot token (or just run the TUI / HTTP API instead).
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────
# From @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric chat IDs allowed to command the bot (from @userinfobot).
# LEAVE THIS SET. Empty = anyone who finds the bot can run commands on your machine.
ALLOWED_CHAT_IDS=

# ── Claude (your subscription) ───────────────────────────
# IMPORTANT: do NOT set ANTHROPIC_API_KEY — that switches to per-token API billing.
# This agent runs on your logged-in Claude Code subscription. For detached/always-on
# runs, generate a long-lived token with `claude setup-token` and paste it here.
# CLAUDE_CODE_OAUTH_TOKEN=
#
# Optional model override (leave empty for the SDK default).
# HERMES_MODEL=claude-opus-4-8
# Working directory the agent operates from (default: your home directory).
# HERMES_CWD=/Users/you

# ── Memory (FTS5 SQLite, always on) ──────────────────────
# The searchable conversation history lives in .data/memory.db automatically.
# Set this to 1 to also auto-inject relevant past context before each prompt.
# HERMES_RECALL=1

# ── HTTP API + web console ───────────────────────────────
# Inert until HERMES_HTTP_PORT is set. Then the agent serves:
#   GET  /                     → web console (open in a browser)
#   POST /v1/chat/completions  → OpenAI-compatible (+ stream:true)
#   GET  /v1/models · GET /api/jobs · POST /api/jobs/:name/run
#   GET  /api/memory/search?q= · GET /api/memory/profile
#   GET  /api/skills · POST /api/skills/install
# HERMES_API_TOKEN is the Bearer key every call (except /health and /) needs.
# HERMES_HTTP_PORT=8787
# HERMES_API_TOKEN=

# ── Extra channels (optional) ────────────────────────────
# Discord: create a bot at https://discord.com/developers, enable the "Message
# Content" intent, invite it to your server. Inert until DISCORD_BOT_TOKEN is set.
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USER_IDS=

# ── Sandboxing (where the agent's own shell runs) ────────
#   local (default) · docker · ssh · modal · daytona
# HERMES_SANDBOX=local
# HERMES_SANDBOX_IMAGE=alpine:3.20
# HERMES_SANDBOX_NETWORK=none
# HERMES_SANDBOX_MEMORY=512m
# HERMES_SANDBOX_CPUS=1
# HERMES_SSH_TARGET=user@host

# ── Skills (agentskills.io-compatible) ───────────────────
# Folder the agent discovers/creates skills in. Default: ~/.hermes/skills
# HERMES_SKILLS_DIR=

# ── Computer use (desktop control) ───────────────────────
# Desktop screenshots work out of the box (macOS `screencapture`). Mouse/keyboard
# control is OFF by default — set this to 1 AND install cliclick to enable it.
# HERMES_COMPUTER_USE=1

# ── Installer CLI ────────────────────────────────────────
# Optional: the launchd service label `npm run agent -- doctor` checks for.
# AGENT_LAUNCHD_LABEL=com.claude-max-agent.app
